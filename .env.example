# FluxCD EZY — Environment Variables Example
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git (it is already in .gitignore).
#
# After filling in values, use them to replace placeholders in YAML files.
# Search for all placeholders: grep -r "<YOUR_" . --include="*.yaml"

# =============================================================================
# GITHUB / FLUXCD BOOTSTRAP
# =============================================================================

# Your GitHub username (used in flux bootstrap and gotk-sync.yaml)
GITHUB_USERNAME=<YOUR_GITHUB_USERNAME>

# Your repository name (forked from this repository)
GITHUB_REPO=<YOUR_REPO_NAME>

# GitHub Personal Access Token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>

# Cluster path (e.g., k0s for production, k0s-staging for staging)
CLUSTER_PATH=k0s

# =============================================================================
# DOMAIN & EMAIL
# =============================================================================

# Your base domain (e.g., yourdomain.com)
BASE_DOMAIN=example.com

# Your local subdomain prefix (e.g., local.yourdomain.com)
# Used for internal IngressRoutes (*.local.example.com → *.local.yourdomain.com)
LOCAL_DOMAIN=local.example.com

# Email address for Let's Encrypt ACME registration and Cloudflare DNS
ACME_EMAIL=your-email@example.com

# =============================================================================
# CLOUDFLARE (for cert-manager DNS-01 challenge)
# =============================================================================

# Cloudflare account email
CLOUDFLARE_EMAIL=your-email@example.com

# Cloudflare API token with Zone:DNS:Edit permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=<YOUR_CLOUDFLARE_API_TOKEN>

# =============================================================================
# METALLB (bare-metal load balancer)
# =============================================================================

# IP address range for LoadBalancer services (must be free in your LAN)
# Example: 192.168.50.50-192.168.50.60
METALLB_IP_RANGE=<YOUR_METALLB_IP_RANGE>

# =============================================================================
# TRAEFIK (ingress controller)
# =============================================================================

# Static IP for Traefik from your MetalLB pool (first IP is a good choice)
# Example: 192.168.50.50
TRAEFIK_LB_IP=<YOUR_TRAEFIK_LOADBALANCER_IP>

# =============================================================================
# CEPH STORAGE
# =============================================================================

# Ceph cluster UUID — get with: ceph fsid
CEPH_CLUSTER_ID=<YOUR_CEPH_CLUSTER_ID>

# Ceph monitor IP addresses — get with: ceph mon dump
CEPH_MONITOR_1=<YOUR_CEPH_MONITOR_IP_1>
CEPH_MONITOR_2=<YOUR_CEPH_MONITOR_IP_2>
CEPH_MONITOR_3=<YOUR_CEPH_MONITOR_IP_3>

# Ceph RBD (block storage) user
# Create with: ceph auth get-or-create client.kubernetes mon 'profile rbd' osd 'profile rbd pool=kubernetes'
CEPH_RBD_USER_ID=<YOUR_CEPH_USER_ID>
# Get with: ceph auth get-key client.kubernetes
CEPH_RBD_USER_KEY=<YOUR_CEPH_RBD_USER_KEY>
CEPH_RBD_POOL=<YOUR_CEPH_RBD_POOL_NAME>

# Ceph CephFS (shared filesystem) admin user
CEPH_ADMIN_ID=<YOUR_CEPH_ADMIN_ID>
# Get with: ceph auth get-key client.admin
CEPH_CEPHFS_USER_KEY=<YOUR_CEPH_CEPHFS_USER_KEY>
CEPHFS_NAME=<YOUR_CEPHFS_NAME>

# =============================================================================
# BITWARDEN (External Secrets Operator backend)
# =============================================================================

# Bitwarden server URL (use https://vault.bitwarden.com for cloud)
BW_HOST=https://vault.bitwarden.com

# Bitwarden API credentials — get at: https://vault.bitwarden.com/#/settings/security
BW_CLIENT_ID=<YOUR_BW_CLIENT_ID>
BW_CLIENT_SECRET=<YOUR_BW_CLIENT_SECRET>
BW_MASTER_PASSWORD=<YOUR_BW_MASTER_PASSWORD>

# Bitwarden vault item IDs — get with: bw list items --search "name" | jq '.[0].id'
BW_ITEM_ID_CLOUDFLARE=<YOUR_BITWARDEN_ITEM_ID_CLOUDFLARE>
BW_ITEM_ID_MEALIE_DB=<YOUR_BITWARDEN_ITEM_ID_MEALIE_DB>
BW_ITEM_ID_NEXTCLOUD_DB=<YOUR_BITWARDEN_ITEM_ID_NEXTCLOUD_DB>
BW_ITEM_ID_NEXTCLOUD_S3=<YOUR_BITWARDEN_ITEM_ID_NEXTCLOUD_S3>
BW_ITEM_ID_OPEN_WEBUI=<YOUR_BITWARDEN_ITEM_ID_OPEN_WEBUI>
BW_ITEM_ID_CLOUDFLARE_TUNNEL=<YOUR_BITWARDEN_ITEM_ID_CLOUDFLARE_TUNNEL>
BW_ITEM_ID_GITHUB_TOKEN=<YOUR_BITWARDEN_ITEM_ID_GITHUB_TOKEN>

# =============================================================================
# POSTGRESQL (external database server)
# =============================================================================

# IP address of your external PostgreSQL server
# Example: 192.168.50.4
POSTGRES_SERVER=<YOUR_POSTGRES_SERVER_IP>

# =============================================================================
# S3 / MINIO (object storage for Nextcloud)
# =============================================================================

# MinIO/S3 endpoint (without protocol)
# Example: minio.local.example.com or 192.168.50.113:9000
S3_ENDPOINT=<YOUR_S3_ENDPOINT>

# Nextcloud S3 bucket name
S3_BUCKET=nextcloud

# S3 credentials — store in Bitwarden, never commit directly
# S3_ACCESS_KEY=<YOUR_S3_ACCESS_KEY>  # Use Bitwarden item instead
# S3_SECRET_KEY=<YOUR_S3_SECRET_KEY>  # Use Bitwarden item instead

# =============================================================================
# HOME ASSISTANT
# =============================================================================

# Dedicated IP for Home Assistant LoadBalancer service (from MetalLB pool)
# Example: 192.168.50.52
HOME_ASSISTANT_LB_IP=<YOUR_HOME_ASSISTANT_LB_IP>

# =============================================================================
# DAHUA VTO (IP Intercom / Doorbell — optional)
# =============================================================================

# IP address of your Dahua VTO device
DAHUA_VTO_IP=<YOUR_DAHUA_VTO_IP>
DAHUA_VTO_USER=admin
# Store in SealedSecret — do not set here
# DAHUA_VTO_PASSWORD=<stored in SealedSecret>

# =============================================================================
# MQTT BROKER (for Home Assistant integrations)
# =============================================================================

# MQTT broker hostname or IP
MQTT_BROKER_HOST=<YOUR_MQTT_BROKER_HOST>
MQTT_BROKER_PORT=1883
MQTT_BROKER_USER=mqtt-user
# Store in SealedSecret — do not set here
# MQTT_BROKER_PASSWORD=<stored in SealedSecret>

# =============================================================================
# OLLAMA (local LLM inference server)
# =============================================================================

# IP address of your external Ollama server
# Example: 192.168.50.100
OLLAMA_SERVER_IP=<YOUR_OLLAMA_SERVER_IP>

# =============================================================================
# STAGING CLUSTER (k0s-staging)
# =============================================================================

# Staging MetalLB IP range (separate from production)
# Example: 192.168.50.200-192.168.50.209
STAGING_METALLB_IP_RANGE=<YOUR_STAGING_METALLB_IP_RANGE>

